# OpenRouter API Key (required for AI features — get yours at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database URL (defaults to SQLite if not set)
DATABASE_URL=sqlite:////app/data/genai_marketing_lab.db

# CORS Origins (comma-separated, defaults to localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App Environment
ENV=development

# Secret key for session signing — any random string works locally
SECRET_KEY=change-me-in-production

# SQLAdmin credentials — login at http://localhost:3000/admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Claude max_tokens per response (default: 4096)
MAX_TOKENS=4096

# Rate limit for AI generate endpoints (requests per minute per IP)
RATE_LIMIT=10/minute
